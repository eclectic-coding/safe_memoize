#!/usr/bin/env ruby
# frozen_string_literal: true

require "date"
require "optparse"
require_relative "../lib/safe_memoize/release_tooling"

root = File.expand_path("..", File.dirname(__FILE__))
version_file = File.join(root, "lib/safe_memoize/version.rb")
changelog_file = File.join(root, "CHANGELOG.md")
roadmap_file = File.join(root, "ROADMAP.md")
release_date = Date.today
dry_run = false

parser = OptionParser.new do |opts|
  opts.banner = "Usage: bin/release VERSION [--date YYYY-MM-DD] [--dry-run]"

  opts.on("--date YYYY-MM-DD", "Override the release date written to CHANGELOG.md") do |value|
    release_date = Date.iso8601(value)
  end

  opts.on("--dry-run", "Validate the release without changing files, committing, or tagging") do
    dry_run = true
  end
end

parser.parse!
version = ARGV.first
abort(parser.to_s) unless version

normalized_version = SafeMemoize::ReleaseTooling.normalize_version(version)
release_message = "Release v#{normalized_version}"

version_contents = File.read(version_file)
changelog_contents = File.read(changelog_file)
roadmap_contents = File.read(roadmap_file)
updated_version_contents = SafeMemoize::ReleaseTooling.update_version_file(version_contents, normalized_version)
updated_changelog_contents = SafeMemoize::ReleaseTooling.finalize_changelog(changelog_contents, normalized_version, release_date)
updated_roadmap_contents = SafeMemoize::ReleaseTooling.prune_roadmap(roadmap_contents)

if dry_run
  puts "Validated #{release_message}."
  puts "Would update #{version_file} and #{changelog_file}."
  if updated_roadmap_contents != roadmap_contents
    puts "Would prune fully-shipped milestone sections from #{roadmap_file}."
  end
  exit 0
end

git_status = IO.popen(%w[git status --porcelain], chdir: root, &:read)
unless git_status.empty?
  abort "Working tree must be clean before running bin/release"
end

File.write(version_file, updated_version_contents)
File.write(changelog_file, updated_changelog_contents)
File.write(roadmap_file, updated_roadmap_contents)

commands = [
  ["git", "add", version_file, changelog_file, roadmap_file],
  ["git", "commit", "-m", release_message],
  ["git", "tag", "-a", "v#{normalized_version}", "-m", release_message]
]

commands.each do |command|
  system(*command, chdir: root, exception: true)
end

puts <<~OUTPUT
  Prepared #{release_message}.

  Next steps:
    git push origin HEAD
    git push origin v#{normalized_version}

  Pushing the tag will trigger the GitHub Actions workflow that publishes the gem to RubyGems and creates the GitHub release.
OUTPUT

